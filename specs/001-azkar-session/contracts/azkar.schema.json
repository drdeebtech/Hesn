{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hesn Azkar Data",
  "description": "Read-only bundled content (assets/azkar.json). Text and repeat counts are verbatim from Hisn al-Muslim and MUST NOT be altered. quran items are immutable.",
  "type": "array",
  "minItems": 2,
  "items": {
    "type": "object",
    "required": ["id", "title", "items"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "enum": ["morning", "evening"] },
      "title": { "type": "string", "minLength": 1 },
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["id", "type", "text", "repeat", "source"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "type": { "type": "string", "enum": ["dhikr", "quran"] },
            "text": { "type": "string", "minLength": 1 },
            "repeat": { "type": "integer", "minimum": 1 },
            "countPhrase": { "type": "string", "minLength": 1 },
            "source": { "type": "string", "minLength": 1 },
            "ref": { "type": "string", "pattern": "^[0-9]+:[0-9]+(-[0-9]+)?$" }
          },
          "allOf": [
            {
              "if": { "properties": { "type": { "const": "quran" } } },
              "then": { "required": ["ref"] }
            }
          ]
        }
      }
    }
  }
}
